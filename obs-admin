#!/bin/sh
obs_admin_load_env_file() {
  env_file=$1
  [ -f "$env_file" ] || return 0

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
      OBS_CONFIG=*|OBS_DATABASE__PATH=*)
        key=${line%%=*}
        value=${line#*=}
        case "$value" in
          \"*)
            value=${value#\"}
            value=${value%\"}
            ;;
          \'*)
            value=${value#\'}
            value=${value%\'}
            ;;
        esac
        export "$key=$value"
        ;;
    esac
  done < "$env_file"
}

obs_admin_app_dir=${OBS_ADMIN_APP_DIR:-/opt/obs}
obs_admin_python=${OBS_ADMIN_PYTHON:-$obs_admin_app_dir/venv/bin/python3}
obs_admin_env_file=${OBS_ADMIN_ENV_FILE:-/etc/obs.env}

if [ -d "$obs_admin_app_dir/obs" ] && [ -x "$obs_admin_python" ]; then
  obs_admin_load_env_file "$obs_admin_env_file"
  cd "$obs_admin_app_dir" || exit 1
  exec "$obs_admin_python" -m obs.admin_cli "$@"
fi
if [ -d /app/obs ]; then
  cd /app || exit 1
  exec python3 -m obs.admin_cli "$@"
fi
if [ -x ./.venv/bin/python3 ]; then
  exec ./.venv/bin/python3 -m obs.admin_cli "$@"
fi
exec python3 -m obs.admin_cli "$@"
